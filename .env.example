# --- Session signing ---
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-128-char-hex
SESSION_COOKIE_NAME=focus_session

# --- App ---
APP_BASE_URL=https://your-domain.example.com

# Auth: there are no auth env vars. The first time you open the app with an
# empty database, the login page becomes a one-time signup that creates the
# admin account. After that, the admin manages other users from /admin and
# everyone changes their own password / TOTP from /settings.

# ============================================================
# LLM + Voice (OpenAI-compatible chat-completions + Whisper)
# Default: Groq. Swap providers via LLM_BASE_URL + LLM_MODEL.
# ============================================================
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
WHISPER_MODEL=whisper-large-v3-turbo
