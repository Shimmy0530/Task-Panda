# --- Session signing ---
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-128-char-hex
SESSION_COOKIE_NAME=focus_session

# --- Password ---
# Generate with: python3 bin/hash-password.py
# (Or run inside a one-off container — see README)
# Keep the single-quotes — bcrypt hashes contain $ which docker-compose
# would otherwise interpret as variable substitution.
AUTH_PASSWORD_HASH='$2b$12$replace_this_with_real_bcrypt_hash'

# --- Optional 2FA (recommended) ---
# Generate with: python3 bin/setup-2fa.py
# Leave blank to disable 2FA entirely.
AUTH_TOTP_SECRET=

# --- App ---
APP_BASE_URL=https://your-domain.example.com

# ============================================================
# LLM + Voice (OpenAI-compatible chat-completions + Whisper)
# Default: Groq. Swap providers via LLM_BASE_URL + LLM_MODEL.
# ============================================================
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
WHISPER_MODEL=whisper-large-v3-turbo
